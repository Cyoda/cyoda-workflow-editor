    "@cyoda/workflow-layout": "workspace:*",
    "@cyoda/workflow-monaco": "workspace:*",
    "@cyoda/workflow-react": "workspace:*",
    "@cyoda/workflow-viewer": "workspace:*",
    "monaco-editor": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "reactflow": "catalog:"
  },
  "devDependencies": {
    "@testing-library/react": "catalog:",
    "@playwright/test": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "jsdom": "catalog:",
    "vite": "catalog:"
  }
}
