{
  "name": "@cyoda/docs-embed-demo",
  "version": "0.0.0",
  "private": true,
  "description": "Capability showcase and regression harness for the Cyoda workflow editor packages.",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
