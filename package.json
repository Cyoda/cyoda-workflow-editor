{
  "name": "cyoda-workflow-editor",
  "version": "0.0.0",
  "private": true,
  "description": "Cyoda Workflow Editor monorepo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Cyoda-platform/cyoda-workflow-editor.git",
    "directory": "."
  },
  "homepage": "https://github.com/Cyoda-platform/cyoda-workflow-editor#readme",
  "bugs": {
    "url": "https://github.com/Cyoda-platform/cyoda-workflow-editor/issues"
  },
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.15.9",
  "pnpm": {
    "overrides": {
      "react": "^18.3.1",
      "react-dom": "^18.3.1",
      "form-data@>=4.0.0 <4.0.6": ">=4.0.6",
      "@babel/core@<7.29.6": "^7.29.6",
      "esbuild@>=0.27.0 <0.28.1": "0.28.1",
      "js-yaml@>=4.0.0 <4.2.0": "4.2.0"
    }
  },
  "scripts": {
    "build": "pnpm -r --filter=\"./packages/*\" run build",
    "test": "pnpm -r --filter=\"./packages/*\" run test",
    "test:watch": "pnpm -r --filter=\"./packages/*\" run test:watch",
    "bench": "pnpm -r --filter=\"./packages/*\" run bench",
    "typecheck": "pnpm -r --filter=\"./packages/*\" run typecheck",
    "lint": "eslint packages apps --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "node ./scripts/release-publish.mjs",
    "release:preflight": "node ./scripts/release-preflight.mjs",
    "prerelease:enter": "changeset pre enter",
    "prerelease:exit": "changeset pre exit"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^8.57.0",
    "prettier": "^3.8.4",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=20"
  }
}
