# Pin the default npm registry to public npm so Dependabot (and any environment
# without a private-registry-scoped ~/.npmrc) resolves public packages from
# registry.npmjs.org rather than the org's GitHub Packages mirror, whose @types/*
# manifests are stale (e.g. it lacks @types/uuid@9.0.8) and break version resolution.
# All @cyoda/* deps are workspace:* and are never fetched from a registry.
registry=https://registry.npmjs.org/
