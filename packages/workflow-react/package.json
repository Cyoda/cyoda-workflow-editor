{
  "name": "@cyoda/workflow-react",
  "version": "0.2.0",
  "description": "Browser-based React editor shell for Cyoda workflows.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Cyoda-platform/cyoda-workflow-editor.git",
    "directory": "packages/workflow-react"
  },
  "homepage": "https://github.com/Cyoda-platform/cyoda-workflow-editor#readme",
  "bugs": {
    "url": "https://github.com/Cyoda-platform/cyoda-workflow-editor/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@cyoda/workflow-core": "workspace:*",
    "@cyoda/workflow-graph": "workspace:*",
    "@cyoda/workflow-layout": "workspace:*",
    "@cyoda/workflow-monaco": "workspace:*",
    "@cyoda/workflow-viewer": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.3.1 || ^19.0.0",
    "react-dom": "^18.3.1 || ^19.0.0",
    "reactflow": "^11"
  },
  "devDependencies": {
    "@testing-library/dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "jsdom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "reactflow": "catalog:"
  }
}
