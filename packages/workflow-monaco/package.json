{
  "name": "@cyoda/workflow-monaco",
  "version": "0.1.0",
  "description": "Monaco JSON editor wired to the Cyoda workflow domain — schema registration, validation markers, debounced replaceSession.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Cyoda-platform/cyoda-workflow-editor.git",
    "directory": "packages/workflow-monaco"
  },
  "homepage": "https://github.com/Cyoda-platform/cyoda-workflow-editor#readme",
  "bugs": {
    "url": "https://github.com/Cyoda-platform/cyoda-workflow-editor/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@cyoda/workflow-core": "workspace:*",
    "jsonc-parser": "^3.2.1",
    "zod-to-json-schema": "^3.22.5"
  },
  "peerDependencies": {
    "monaco-editor": ">=0.45 <0.53",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "monaco-editor": "^0.50.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
