{
  "name": "@cyoda/workflow-graph",
  "version": "0.2.0",
  "description": "Cyoda workflow graph projection: domain → nodes/edges/annotations; canvas edits → domain patches.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Cyoda-platform/cyoda-workflow-editor.git",
    "directory": "packages/workflow-graph"
  },
  "homepage": "https://github.com/Cyoda-platform/cyoda-workflow-editor#readme",
  "bugs": {
    "url": "https://github.com/Cyoda-platform/cyoda-workflow-editor/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@cyoda/workflow-core": "workspace:*"
  }
}
