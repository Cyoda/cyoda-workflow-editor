{
  "name": "@cyoda/workflow-layout",
  "version": "0.1.2",
  "description": "Layout adapter for Cyoda workflow graphs (three presets, sync + worker).",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Cyoda-platform/cyoda-workflow-editor.git",
    "directory": "packages/workflow-layout"
  },
  "homepage": "https://github.com/Cyoda-platform/cyoda-workflow-editor#readme",
  "bugs": {
    "url": "https://github.com/Cyoda-platform/cyoda-workflow-editor/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@cyoda/workflow-core": "workspace:*",
    "@cyoda/workflow-graph": "workspace:*",
    "elkjs": "catalog:"
  }
}
